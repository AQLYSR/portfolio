---
import Layout from '../layouts/Layout.astro';
import PixelIcon from '../components/PixelIcon.astro';
import { getCollection } from 'astro:content';

const photosRaw = await getCollection('gallery');
const photos = photosRaw
  .map((p) => p.data)
  .sort((a, b) => a.order - b.order);

const filters = [
  { key: 'all', label: 'All' },
  { key: 'portrait', label: 'Portrait' },
  { key: 'scenery', label: 'Scenery' },
  { key: 'food', label: 'Food' },
  { key: 'street', label: 'Street' },
  { key: 'travel', label: 'Travel' },
];
---

<Layout title="Gallery" current="gallery" description="Browse portrait, scenery, food, street, and travel photography by Aqil Yusri.">
  <section class="gallery-section">
    <div class="wrap">
      <div class="section-heading">
        <PixelIcon name="flag" size={26} color="var(--red)" />
        <h1>Gallery</h1>
      </div>

      <div class="filters" role="tablist" aria-label="Filter photos by category">
        {filters.map((f, i) => (
          <button
            class={`filter-btn${i === 0 ? ' active' : ''}`}
            data-filter={f.key}
            type="button"
          >
            {f.label}
          </button>
        ))}
      </div>

      <div class="photo-grid" id="photo-grid">
        {photos.map((p) => (
          <a
            class="gallery-item"
            data-category={p.category}
            href={p.image}
            target="_blank"
            rel="noopener noreferrer"
          >
            <img src={p.image} alt={p.alt || p.title} loading="lazy" width="500" height="500" />
            <span class="caption">{p.title}</span>
          </a>
        ))}
      </div>

      <div class="load-more-wrap">
        <button id="load-more" class="btn btn-yellow">Load More ↓</button>
      </div>
    </div>
  </section>
</Layout>

<style>
  .gallery-section {
    padding: 20px 0 60px;
  }

  .section-heading {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 30px;
  }

  .section-heading h1 {
    font-size: 1.6rem;
    color: var(--blue);
  }

  .filters {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-bottom: 30px;
  }

  .filter-btn {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 0.85rem;
    padding: 10px 18px;
    border: 2px solid var(--ink);
    background: transparent;
    color: var(--ink);
    border-radius: var(--radius);
  }

  .filter-btn.active {
    background: var(--blue);
    color: var(--cream-soft);
    border-color: var(--blue);
  }

  .filter-btn:hover:not(.active) {
    background: rgba(29, 63, 145, 0.08);
  }

  .photo-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
  }

  .gallery-item {
    position: relative;
    display: block;
    overflow: hidden;
    border: 3px solid var(--ink);
    aspect-ratio: 1 / 1;
  }

  .gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.35s ease;
  }

  .gallery-item:hover img {
    transform: scale(1.06);
  }

  .caption {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    padding: 10px 12px;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.65), transparent);
    color: #fff;
    font-size: 0.8rem;
    font-weight: 600;
    opacity: 0;
    transition: opacity 0.25s ease;
  }

  .gallery-item:hover .caption {
    opacity: 1;
  }

  .load-more-wrap {
    display: flex;
    justify-content: center;
    margin-top: 40px;
  }

  @media (max-width: 800px) {
    .photo-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .photo-grid {
      grid-template-columns: 1fr 1fr;
      gap: 12px;
    }
  }
</style>

<script>
  const BATCH_SIZE = 9;
  const items = Array.from(document.querySelectorAll('.gallery-item'));
  const filterBtns = Array.from(document.querySelectorAll('.filter-btn'));
  const loadMoreBtn = document.getElementById('load-more');

  let visibleCount = BATCH_SIZE;
  let activeFilter = 'all';

  function render() {
    let matchedSoFar = 0;
    items.forEach((item) => {
      const cat = item.dataset.category;
      const matches = activeFilter === 'all' || cat === activeFilter;

      if (!matches) {
        item.style.display = 'none';
        return;
      }

      if (activeFilter !== 'all') {
        item.style.display = '';
        return;
      }

      matchedSoFar++;
      item.style.display = matchedSoFar <= visibleCount ? '' : 'none';
    });

    if (loadMoreBtn) {
      loadMoreBtn.style.display = activeFilter === 'all' && visibleCount < items.length ? '' : 'none';
    }
  }

  filterBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      filterBtns.forEach((b) => b.classList.remove('active'));
      btn.classList.add('active');
      activeFilter = btn.dataset.filter || 'all';
      visibleCount = BATCH_SIZE;
      render();
    });
  });

  loadMoreBtn?.addEventListener('click', () => {
    visibleCount += BATCH_SIZE;
    render();
  });

  render();
</script>
