---
import Layout from "../layouts/Layout.astro";
import { getEntry } from "astro:content";
import { markdownToHtml } from "../utils/markdown";

const terms = await getEntry("terms", "index");
const d = terms.data;
---

<Layout
    title="Terms & Conditions"
    description="Terms and Conditions for Aqil Yusri Photography."
>
    <div class="wrap legal-page">
        <h1 set:html={d.heading} />
        <div class="legal-body" set:html={markdownToHtml(d.body)} />
    </div>
</Layout>

<style>
    .legal-page {
        padding: 60px 0 80px;
        max-width: 720px;
    }

    .legal-page h1 {
        font-size: 1.8rem;
        margin-bottom: 32px;
        color: var(--green);
    }

    .legal-body :global(h2) {
        font-size: 1.15rem;
        margin-top: 28px;
        margin-bottom: 10px;
        color: var(--ink);
    }

    .legal-body :global(p) {
        color: #3a3a3a;
        line-height: 1.75;
        margin-bottom: 14px;
    }
</style>
