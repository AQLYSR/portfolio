---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

export interface Props {
  title: string;
  description?: string;
  current?: 'home' | 'gallery' | 'about' | 'contact';
}

const {
  title,
  description = 'Aqil Yusri — portrait, event, and lifestyle photography based in Malaysia.',
  current = 'home',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="description" content={description} />
    <title>{title} | Aqil Yusri Photography</title>
  </head>
  <body>
    <Header current={current} />
    <main>
      <slot />
    </main>
    <Footer />

    <!-- Netlify Identity: required so invite / password-recovery links (which point
         to the site root) can open the widget and redirect back into /admin/. -->
    <script is:inline src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
    <script is:inline>
      if (window.netlifyIdentity) {
        window.netlifyIdentity.on('init', (user) => {
          if (!user) {
            window.netlifyIdentity.on('login', () => {
              document.location.href = '/admin/';
            });
          }
        });
      }
    </script>
  </body>
</html>
