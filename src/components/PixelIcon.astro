---
// Hand-drawn pixel-grid icons to match the retro/8-bit aesthetic of the site.
// Most icons are 8x8. Social icons (instagram, tiktok, youtube, whatsapp) use
// 12x12 grids for enough detail to be recognisable.
// '#' = filled pixel, '.' = empty.

export interface Props {
    name:
        | "mushroom"
        | "star"
        | "heart"
        | "flag"
        | "camera"
        | "mountain"
        | "fork"
        | "suitcase"
        | "mail"
        | "phone"
        | "pin"
        | "instagram"
        | "youtube"
        | "tiktok"
        | "whatsapp"
        | "lens"
        | "behance"
        | "grid";
    size?: number;
    color?: string;
    class?: string;
}

const {
    name,
    size = 24,
    color = "currentColor",
    class: className = "",
} = Astro.props;

