    '.#....#.',
    '.#....#.',
    '.#....#.',
  ],
  suitcase: [
    '..####..',
    '.######.',
    '########',
    '##.##.##',
    '########',
    '########',
    '.######.',
    '........',
  ],
  mail: [
    '########',
    '#......#',
    '##....##',
    '#.#..#.#',
    '#..##..#',
    '#......#',
    '########',
    '........',
  ],
  phone: [
    '..####..',
    '.#....#.',
    '.#....#.',
    '.#....#.',
    '.#....#.',
    '.#....#.',
    '.#....#.',
    '..####..',
  ],
  pin: [
    '..####..',
    '.#....#.',
