---
// Hand-drawn 8x8 pixel-grid icons to match the retro/8-bit aesthetic of the site.
// Each icon is an array of 8 strings (8 chars each). '#' = filled pixel, '.' = empty.

export interface Props {
  name:
    | 'mushroom'
    | 'star'
    | 'heart'
    | 'flag'
    | 'camera'
    | 'mountain'
    | 'fork'
    | 'suitcase'
    | 'mail'
    | 'phone'
    | 'pin'
    | 'instagram'
    | 'youtube'
    | 'lens'
    | 'behance'
    | 'grid';
  size?: number;
  color?: string;
  class?: string;
}

const { name, size = 24, color = 'currentColor', class: className = '' } = Astro.props;

const GRIDS: Record<string, string[]> = {
  mushroom: [
    '..####..',
    '.######.',
    '########',
    '########',
    '.#.##.#.',
    '.#.##.#.',
    '.#.##.#.',
    '.######.',
  ],
  star: [
    '...##...',
    '..####..',
    '.######.',
    '########',
    '.######.',
    '.#....#.',
    '#......#',
    '........',
  ],
  heart: [
    '.##..##.',
    '########',
    '########',
    '.######.',
    '..####..',
    '...##...',
    '........',
    '........',
  ],
  flag: [
    '##..##..',
    '##..##..',
    '..##..##',
    '..##..##',
    '##..##..',
    '##..##..',
    '..##..##',
    '..##..##',
  ],
  camera: [
    '..####..',
    '.######.',
    '########',
    '##.##.##',
    '##.##.##',
    '########',
    '########',
    '........',
  ],
  mountain: [
    '........',
    '..#..#..',
    '.###.##.',
    '.#####.#',
    '########',
    '########',
    '........',
    '........',
  ],
  fork: [
    '#.#..##.',
