const grid = GRIDS[name] ?? GRIDS.star;
const dimension = grid.length;
const cell = size / dimension;
---

<svg
    class={`pixel-icon ${className}`}
    width={size}
    height={size}
    viewBox={`0 0 ${size} ${size}`}
    xmlns="http://www.w3.org/2000/svg"
    aria-hidden="true"
    focusable="false"
>
    {
        grid.flatMap((row, y) =>
            row
                .split("")
                .map((c, x) =>
                    c === "#" ? (
                        <rect
                            x={x * cell}
                            y={y * cell}
                            width={cell}
                            height={cell}
                            fill={color}
                        />
                    ) : null,
                ),
        )
    }
</svg>
